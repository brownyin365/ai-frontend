{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/react"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ],
  "env": {
    "REACT_APP_API_URL": "https://ai-backend-red.vercel.app/api",
    "REACT_APP_WS_URL": "wss://ai-backend-red.vercel.app"
  },
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "build"
}
